{
  "name": "oracle-personal-docs",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "fetch:schema": "node scripts/fetch-schema.mjs",
    "fetch:schema:dry": "node scripts/fetch-schema.mjs --dry-run",
    "scrape:schema": "node scripts/scrape-schema.mjs",
    "sync:schema": "node scripts/fetch-schema.mjs && node scripts/scrape-schema.mjs"
  },
  "dependencies": {
    "@react-router/node": "7.15.0",
    "@react-router/serve": "7.15.0",
    "crawler.dev": "0.2.6",
    "fuse.js": "^7.3.0",
    "gray-matter": "^4.0.3",
    "isbot": "^5.1.36",
    "lucide-react": "^1.14.0",
    "mermaid": "^11.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "react-router": "7.15.0",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@react-router/dev": "7.15.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "playwright": "^1.59.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.3"
  }
